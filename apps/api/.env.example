DATABASE_URL="postgresql://user:password@localhost:5432/meestock_dev?schema=public"
TEST_DATABASE_URL="postgresql://user:password@localhost:5432/meestock_test?schema=public"
PORT=4000
# Comma-separated allowed origins, e.g. "https://meestock.example.com". Unset = reflect any origin (dev only).
CORS_ORIGIN=
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="8h"
BCRYPT_SALT_ROUNDS=10
MATERIAL_ISSUE_APPROVAL_SLA_HOURS=24
MATERIAL_ISSUE_FULFILLMENT_SLA_DAYS=3

# One-off script only (prisma/importLandmarkStock.ts), not read by the app itself.
# Absolute path to the source .xlsx being imported.
LANDMARK_EXCEL_PATH=
